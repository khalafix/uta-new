section.slider
  .container
    .slider__wrapper
      .slider-col  
        .slider__content
            p.slider-text.slider-sotitle Apply in minutes
            h1.slider-text.slider-title Get Approved In Hours
            a.slider-btn(href="#") Read More
            p.enjoy-dubai Now is the Time to Enjoy Dubai ...
      .slider-col 
        .slider__images
            img.img1(src="/assets/img/slider/slider-01.png" alt="")
            img.img2(src="/assets/img/slider/slider-02.png" alt="")
            img.img3(src="/assets/img/slider/slider-03.png" alt="")
    img.img4.cloud(src="/assets/img/slider/Large_Cloud_Transparent_PNG_Image01.png" alt="")
    img.img5.plane(src="/assets/img/slider/a380-aircraft.png" alt="")
    img.img6.cloud(src="/assets/img/slider/Large_Cloud_Transparent_PNG_Image02.png" alt="")
  img.img-bottom(src="/assets/img/slider/slider-bg.png" alt="")
   
    
section.whychoose-uta
  .container
      .uta-col.pl-30
        h2 Why Book a Dubai Bus Tour?
        p Enjoy panoramic views as you explore Dubai’s modern skyline and historic districts. Our open-top buses let you hop on and off at the city’s most popular attractions. Live audio guides share fascinating stories and insights along the way. Comfortable seating and flexible routes make sightseeing easy and enjoyable. Capture unforgettable moments while discovering Dubai at your own pace.

      .uta-col.right-images
        img.img9.img-section(src="/assets/img/safari-img-01.png")
        img.img8.img-section(src="/assets/img/girl-in-desert.png")
        img.img7.img-section(src="/assets/img/burj-al-arab.png")
      a.see-more(href="#")  See More
