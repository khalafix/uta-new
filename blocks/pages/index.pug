extends ../layout.pug
block head 
    - var pageTitle = "Home Page"
    - var pageDescription = "Test"       
    - var pageKeywords = "Test"       
    include ../head
    block style 
        link(rel='stylesheet' href='https://cdn.jsdelivr.net/npm/swiper/swiper-bundle.min.css')
block body 
    header 
        include ../header
    main 
        section.slider
          .container
            .slider__wrapper
              .slider-col  
                .slider__content
                    p.slider-text.slider-sotitle Apply in minutes
                    h1.slider-text.slider-title Get Approved In Hours
                    a.slider-btn(href="#") Read More
                    p.enjoy-dubai Now is the Time to Enjoy Dubai ...
              .slider-col 
                .slider__images
                    img.img1(src="/assets/img/slider/slider-01.png" alt="")
                    img.img2(src="/assets/img/slider/slider-02.png" alt="")
                    img.img3(src="/assets/img/slider/slider-03.png" alt="")
            img.img4.cloud(src="/assets/img/slider/Large_Cloud_Transparent_PNG_Image01.png" alt="")
            img.img5.plane(src="/assets/img/slider/a380-aircraft.png" alt="")
            img.img6.cloud(src="/assets/img/slider/Large_Cloud_Transparent_PNG_Image02.png" alt="")
          img.img-bottom(src="/assets/img/slider/slider-bg.png" alt="")
      
      
        section.section-01.has-world-bg
          .container.pb-150
              .uta-col.pl-30
                h2 Why Book a Dubai Bus Tour?
                p Enjoy panoramic views as you explore Dubai’s modern skyline and historic districts. Our open-top buses let you hop on and off at the city’s most popular attractions. Live audio guides share fascinating stories and insights along the way. Comfortable seating and flexible routes make sightseeing easy and enjoyable. Capture unforgettable moments while discovering Dubai at your own pace.
      
              .uta-col.right-images
                img.img9.img-section.reveal-item.reveal-from-right(src="/assets/img/safari-img-01.png")
                img.img8.img-section.reveal-item.reveal-from-top(src="/assets/img/girl-in-desert.png")
                img.img7.img-section.reveal-item.reveal-from-left(src="/assets/img/burj-al-arab.png")
              a.see-more(href="#")  See More
          - const attractionTabs = [{id:'visa1', icon:'/assets/img/visa-icon1.svg', id:'visa', icon:'/assets/img/visa-icon.svg', label:'Visa'},{ id:'activity', icon:'/assets/img/activity-icon.svg', label:'Activity'},{ id:'hotel', icon:'/assets/img/hotel-icon.svg', label:'Hotel'},{ id:'tour', icon:'/assets/img/tour-icon.svg', label:'Tour'},{ id:'car', icon:'/assets/img/car-icon.svg', label:'Car'},{ id:'cruise', icon:'/assets/img/cruise-icon.svg', label:'Cruise'}]

          .attractions
            // Tabs
            .attraction-categories(role="tablist")
              each tab, i in attractionTabs
                +hexIcon(tab.icon, tab.label, i === 0, tab.id)
          // Panels
          
          .attraction-tab-panels
            each tab, idx in attractionTabs
              .attraction-tab-panel(
                id='tab-panel-' + tab.id
                data-tab-panel=tab.id
                role="tabpanel"
                class=(idx === 0 ? 'active' : '')
                aria-labelledby='tab-' + tab.id
              )
                .swiper.attraction-slider
                  .swiper-wrapper

                    if tab.id === 'visa'
                      +tourCard("/assets/img/attractions/desert-safari-01.svg","Big Bus + Desert Safari","29","39","15")
                      +tourCard("/assets/img/attractions/desert-safari-01.svg","Big Bus","29","39","25")
                      +tourCard("/assets/img/attractions/desert-safari-01.svg","Visa Express Package","29","39","25")
                      +tourCard("/assets/img/attractions/desert-safari-01.svg","Visa Express Package","29","39","25")
                      
                    else if tab.id === 'activity'
                      +tourCard("/assets/img/attractions/deseart-safari-01.svg","Desert Safari Adventure","72","90","20")
                      +tourCard("/assets/img/attractions/desert-safari-01.svg","Desert Safari Adventure","72","90","20")
                      +tourCard("/assets/img/attractions/desert-safari-01.svg","Desert Safari Adventure","72","90","20")
                      +tourCard("/assets/img/attractions/desert-safari-01.svg","Desert Safari Adventure","72","90","20")
                      
                      
                    else if tab.id === 'hotel'
                      +tourCard("/assets/img/desert2.jpg","Budget Hotel (1 Night)","49","65","25")
                      +tourCard("/assets/img/desert.jpg","Marina View 5★ Stay (1 Night)","169","210","20")
                      +tourCard("/assets/img/desert2.jpg","Budget Hotel (1 Night)","49","65","25")
                     
                    else if tab.id === 'tour'
                      +tourCard("/assets/img/desert.jpg","Big Bus Hop-On Hop-Off Tour","72","90","20")
                      +tourCard("/assets/img/desert3.jpg","Burj Khalifa + City Tour Combo","99","129","23")
                      +tourCard("/assets/img/desert.jpg","Dubai Night City Tour","39","55","29")
                    else if tab.id === 'car'
                      +tourCard("/assets/img/desert2.jpg","Economy Car Rental (1 Day)","35","49","28")
                      +tourCard("/assets/img/desert2.jpg","Old Dubai Walking Tour","25","35","29")
                      +tourCard("/assets/img/desert2.jpg","Old Dubai Walking Tour","25","35","29")
                    
                    else if tab.id === 'cruise'
                      +tourCard("/assets/img/desert3.jpg","Marina Dinner Cruise","55","75","27")
                      +tourCard("/assets/img/desert.jpg","Sunset Yacht Cruise","89","120","26")
                      +tourCard("/assets/img/desert.jpg","Sunset Yacht Cruise","89","120","26")
                     
                    else
                      +tourCard("/assets/img/desert.jpg","Big Bus + Desert Safari 1","72","90","20")
                      +tourCard("/assets/img/desert.jpg","Big Bus + Desert Safari 1","72","90","20")
                     

                  .swiper-button-next
                  .swiper-button-prev      

        section.section-3
          .container
              .uta-col.left-images
                img(src="/assets/img/burj-khalifa.png")
              .uta-col.right-text
                h2 Why Book a Dubai Bus Tour?
                p Enjoy panoramic views as you explore Dubai’s modern skyline and historic districts. Our open-top buses let you hop on and off at the city’s most popular attractions. Live audio guides share fascinating stories and insights along the way. Comfortable seating and flexible routes make sightseeing easy and enjoyable. Capture unforgettable moments while discovering Dubai at your own pace.Enjoy panoramic views as you explore Dubai’s modern skyline and historic districts. Our open-top buses let you hop on and off at the city’s most popular attractions. Live audio guides share fascinating stories.

        section.faq
          .container
            .faq-layout
      
              .faq-left
      
                h2.faq-title FAQ
      
                .faq-wrapper
      
                  .faq-item.active
                    button.faq-question
                      .faq-left-inner
                        .faq-icon
                          img(src="/assets/img/icons/help.svg" alt="")
                        span What is Lorem Ipsum?
                      .faq-toggle ?
      
                    .faq-answer
                      p Lorem Ipsum is simply dummy text of the printing and typesetting industry.
      
                  .faq-item
                    button.faq-question
                      .faq-left-inner
                        .faq-icon
                          img(src="/assets/img/icons/help.svg" alt="")
                        span Where can I get some?
                      .faq-toggle ?
      
                    .faq-answer
                      p Lorem Ipsum is simply dummy text of the printing and typesetting industry.
      
                  .faq-item
                    button.faq-question
                      .faq-left-inner
                        .faq-icon
                          img(src="/assets/img/icons/help.svg" alt="")
                        span Where does it come from?
                      .faq-toggle ?
      
                    .faq-answer
                      p Lorem Ipsum is simply dummy text of the printing and typesetting industry.
      
              .faq-right
                img(src="/assets/img/burj-al-arab-02.png" alt="Burj Al Arab")
block pageScripts 
    script(src="/assets/js/modules/cloud-parallex.js")
    script(src="/assets/js/modules/accordion.js")
    script(src="/assets/js/modules/section01-images-reveal.js")

    script(src='https://cdn.jsdelivr.net/npm/swiper/swiper-bundle.min.js')
    script(src="/assets/js/modules/swipper.js")
    script.
      document.querySelectorAll('[data-tab]').forEach(tab=>{
        tab.addEventListener('click',()=>{

          const id = tab.dataset.tab

          document.querySelectorAll('[role="tab"]').forEach(t=>{
            t.classList.remove('active')
            t.setAttribute('aria-selected','false')
          })

          document.querySelectorAll('[data-tab-panel]').forEach(panel=>{
            panel.classList.remove('active')
          })

          tab.classList.add('active')
          tab.setAttribute('aria-selected','true')

          document.querySelector(`[data-tab-panel="${id}"]`).classList.add('active')

        })
      })
